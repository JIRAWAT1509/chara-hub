# Chara Hub local environment example
#
# Copy this file to .env for local development.
# Do not commit .env.

# Supabase project identity
SUPABASE_PROJECT_REF=
SUPABASE_URL=

# Safe for browser/client use when Row Level Security is configured correctly.
SUPABASE_PUBLISHABLE_KEY=

# Backend-only values. Never expose these in Angular.
SUPABASE_DB_JDBC_URL=
SUPABASE_DB_USERNAME=
SUPABASE_DB_PASSWORD=

